{% extends 'tenant/base.html' %}{% block title %}Attendance | {{ tenant.name }}{% endblock %}{% block body %}<div class="page-header"><div><h1 class="page-title">Daily Attendance</h1><p class="page-desc">Check-in / Check-out members</p></div></div><div class="filter-card"><form method="post" class="attendance-form">{% csrf_token %}<div class="form-row"><div class="form-field"><label>Customer</label>{{ form.customer }}</div><div class="form-field"><label>Check-out (optional)</label>{{ form.check_out }}</div><div class="form-field"><label>Notes</label>{{ form.notes }}</div><div class="form-field"><button type="submit" class="btn-primary">Mark Check-in</button></div></div></form></div><div class="table-card"><h3>Today's Check-ins ({{ checkins_today|length }})</h3><div class="table-responsive"><table class="data-table"><thead><tr><th>Customer</th><th>Check-in Time</th><th>Check-out</th><th>Action</th></tr></thead><tbody>{% for a in checkins_today %}<tr><td><strong>{{ a.customer.name }}</strong><br><small>{{ a.customer.phone }}</small></td><td>{{ a.check_in|time:"H:i" }}</td><td>{% if a.check_out %}{{ a.check_out|time:"H:i" }}{% else %}—{% endif %}</td><td>{% if not a.check_out %}<button class="btn-checkout" data-id="{{ a.customer.id }}">Check-out</button>{% endif %}</td></tr>{% empty %}<tr><td colspan="4">No check-ins today</td></tr>{% endfor %}</tbody></table></div></div><div class="table-card"><h3>Last 7 Days Attendance</h3><div class="table-responsive"><table class="data-table"><thead><tr><th>Date</th><th>Customer</th><th>Check-in</th><th>Check-out</th></tr></thead><tbody>{% for a in recent_attendance %}<tr><td>{{ a.date|date:"Y-m-d" }}</td><td>{{ a.customer.name }}</td><td>{{ a.check_in|time:"H:i" }}</td><td>{{ a.check_out|time:"H:i"|default:"-" }}</td></tr>{% empty %}<tr><td colspan="4">No recent attendance</td></tr>{% endfor %}</tbody></table></div></div><script>function getCookie(name){let c=null;if(document.cookie&&document.cookie!==''){const cookies=document.cookie.split(';');for(let i=0;i<cookies.length;i++){const cookie=cookies[i].trim();if(cookie.substring(0,name.length+1)===(name+'=')){c=decodeURIComponent(cookie.substring(name.length+1));break;}}}return c;}document.querySelectorAll('.btn-checkout').forEach(btn=>{btn.addEventListener('click',async function(){const customerId=this.dataset.id;if(!confirm('Check out this customer?'))return;const resp=await fetch('/api/gym/checkout/',{method:'POST',headers:{'X-CSRFToken':getCookie('csrftoken'),'Content-Type':'application/x-www-form-urlencoded'},body:`customer_id=${customerId}`});const data=await resp.json();if(data.message)alert(data.message);location.reload();});});</script>{% endblock %}