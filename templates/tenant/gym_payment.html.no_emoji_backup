{% extends 'tenant/base.html' %}{% block title %}Collect Payment | {{ tenant.name }}{% endblock %}{% block body %}<div class="page-header"><div><h1 class="page-title">Collect Payment</h1><p class="page-desc">Record subscription payments</p></div></div><div class="students-list-card"><div class="card-header"><h3>Customers with Pending Fees</h3></div><div class="table-responsive"><table class="data-table"><thead><tr><th>Name</th><th>Phone</th><th>Pending</th><th></th></tr></thead><tbody>{% for c in customers %}<tr><td>{{ c.name }}</td><td>{{ c.phone }}</td><td class="pending-amount">₹{{ c.pending_amount|floatformat:2 }}</td><td><a href="{% url 'gym_payment' schema_name=tenant.schema_name customer_id=c.id %}" class="btn-sm">Select</a></td></tr>{% empty %}<tr><td colspan="4">No pending fees</td></tr>{% endfor %}</tbody></table></div></div>{% if selected_customer %}<div class="student-panel"><div class="student-info"><div><h3>{{ selected_customer.name }}</h3><p>{{ selected_customer.phone }} | Pending: ₹{{ total_pending }}</p></div></div><form method="post" class="payment-form">{% csrf_token %}<input type="hidden" name="customer_id" value="{{ selected_customer.id }}"><div class="form-row"><div class="form-field"><label>Amount Received (₹)</label><input type="number" name="amount" step="0.01" required placeholder="Enter amount"></div><div class="form-field"><label>Payment Mode</label><select name="payment_mode"><option value="cash">Cash</option><option value="bank_transfer">Bank Transfer</option><option value="cheque">Cheque</option><option value="online">Online</option></select></div><div class="form-field"><label>Remarks</label><input type="text" name="remarks"></div><div class="form-field submit-field"><button type="submit" class="btn-primary">Process Payment</button></div></div></form><div class="pending-table"><h4>Pending Subscriptions</h4><div class="table-responsive"><table class="data-table"><thead><tr><th>Month/Year</th><th>Amount</th><th>Paid</th><th>Remaining</th></tr></thead><tbody>{% for s in pending_subs %}<tr><td>{{ s.month }}/{{ s.year }}</td><td>₹{{ s.amount }}</td><td>₹{{ s.paid_amount }}</td><td class="remaining">₹{{ s.remaining }}</td></tr>{% empty %}<tr><td colspan="4">No pending subscriptions</td></tr>{% endfor %}</tbody></table></div></div></div>{% endif %}<div class="history-card"><div class="card-header"><h3>Recent Payments</h3><a href="{% url 'gym_reports' schema_name=tenant.schema_name %}?type=revenue" class="view-all">View All →</a></div><div class="table-responsive"><table class="data-table"><thead><tr><th>Receipt</th><th>Customer</th><th>Amount</th><th>Date</th><th>Mode</th><th>Receipt</th></tr></thead><tbody>{% for p in recent_payments %}<tr><td><code>{{ p.receipt_number }}</code></td><td>{{ p.customer.name }}</td><td>₹{{ p.amount|floatformat:2 }}</td><td>{{ p.payment_date|date:"d M Y" }}</td><td>{{ p.get_payment_mode_display }}</td><td><a href="{% url 'gym_receipt' schema_name=tenant.schema_name receipt_id=p.id %}">View</a></td></tr>{% empty %}<tr><td colspan="6">No payments yet</td></tr>{% endfor %}</tbody></table></div></div>{% endblock %}